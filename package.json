{
  "name": "ecommerce-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "audit": "npm audit --audit-level=high --omit=dev",
    "prepare": "husky && git config commit.template .gitmessage",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --selectProjects unit --runInBand",
    "test:acceptance": "jest --selectProjects acceptance --runInBand",
    "test:integration": "jest --selectProjects integration --runInBand",
    "secretlint": "secretlint --secretlintrc .secretlintrc.json \"**/*\"",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs",
    "mutation": "stryker run",
    "mutation:ci": "stryker run --incremental",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "migration:run": "typeorm migration:run -d src/infrastructure/persistence/typeorm/data-source.ts",
    "migration:generate": "typeorm migration:generate -d src/infrastructure/persistence/typeorm/data-source.ts",
    "migration:revert": "typeorm migration:revert -d src/infrastructure/persistence/typeorm/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "secretlint": "^11.3.1",
    "supertest": "^7.2.2",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "jest": {
    "rootDir": ".",
    "coverageDirectory": "./coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/main.ts",
      "!src/infrastructure/persistence/typeorm/data-source.ts",
      "!src/infrastructure/persistence/typeorm/migrations/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 95,
        "statements": 95,
        "branches": 85,
        "functions": 95
      }
    },
    "projects": [
      {
        "displayName": "unit",
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "roots": [
          "<rootDir>/src/"
        ],
        "setupFiles": [
          "<rootDir>/test/setup.ts"
        ]
      },
      {
        "displayName": "acceptance",
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "roots": [
          "<rootDir>/test/acceptance/"
        ],
        "setupFiles": [
          "<rootDir>/test/setup.ts"
        ]
      },
      {
        "displayName": "integration",
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "roots": [
          "<rootDir>/test/integration/"
        ],
        "globalSetup": "<rootDir>/test/integration/global-setup.ts",
        "globalTeardown": "<rootDir>/test/integration/global-teardown.ts"
      }
    ]
  },
  "overrides": {
    "multer": "2.1.1"
  },
  "lint-staged": {
    "**/*": "secretlint --secretlintrc .secretlintrc.json",
    "{src,test}/**/*.ts": [
      "prettier --write",
      "eslint --max-warnings=0"
    ]
  }
}
